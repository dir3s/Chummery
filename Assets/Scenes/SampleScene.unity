    \u0442\u0430 \u041B\u0430\u0432\u0440\u0438\u0449\u0435\u0432 \u041C\u0430\u043A\u0441\u0438\u043C\n\n\u0429\u0438\u0440\u043E
    \u0432\u0434\u044F\u0447\u043D\u0456 \u043A\u043E\u0436\u043D\u043E\u043C\u0443
    \u0433\u0440\u0430\u0432\u0446\u0435\u0432\u0456 \u0437\u0430 \u0443\u0432\u0430\u0433\u0443
    \u0434\u043E \u043D\u0430\u0448\u043E\u0457 \u0440\u043E\u0431\u043E\u0442\u0438.
    \u0412\u0430\u0448 \u0456\u043D\u0442\u0435\u0440\u0435\u0441 - \u0446\u0435
    \u043D\u0430\u0439\u043A\u0440\u0430\u0449\u0430 \u043C\u043E\u0442\u0438\u0432\u0430\u0446\u0456\u044F
    \u0434\u043B\u044F \u043D\u0430\u0441 \u0441\u0442\u0432\u043E\u0440\u044E\u0432\u0430\u0442\u0438
    \u043D\u043E\u0432\u0456 \u0456\u0433\u0440\u0438. \u0414\u044F\u043A\u0443\u0454\u043C\u043E,
    \u0449\u043E \u0432\u0438 \u0437 \u043D\u0430\u043C\u0438!"
