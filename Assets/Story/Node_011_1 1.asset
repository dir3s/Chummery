  background: {fileID: -6918254170140894981, guid: 2c769c0f2d924af4ea0874e186e1074a, type: 3}
  dialogueText: "\u0421\u0432\u0456\u0442\u043B\u043E \u043B\u0430\u043C\u043F \u0441\u0442\u0430\u0454
    \u0432\u0441\u0435 \u0432\u0430\u0436\u0447\u0438\u043C, \u0437\u0430\u043D\u0443\u0440\u044E\u044E\u0447\u0438
    \u0434\u0430\u043B\u0435\u043A\u0443 \u0447\u0430\u0441\u0442\u0438\u043D\u0443
    \u043A\u043E\u0440\u0438\u0434\u043E\u0440\u0443 \u0432 \u043F\u043E\u0432\u043D\u0443
    \u0442\u0435\u043C\u0440\u044F\u0432\u0443. \u0422\u0438 \u0432\u0456\u0434\u0447\u0443\u0432\u0430\u0454\u0448,
    \u044F\u043A \u043F\u043E\u0432\u0456\u0442\u0440\u044F \u0433\u0443\u0441\u0442\u0456\u0448\u0430\u0454..\n\n\u0423
    \u0442\u0430\u043A\u0456 \u043C\u043E\u043C\u0435\u043D\u0442\u0438 \u0437\u0434\u0430\u0454\u0442\u044C\u0441\u044F,
    \u0449\u043E \u043A\u043E\u0440\u0438\u0434\u043E\u0440 \u0441\u0442\u0430\u0454
    \u043D\u0435\u0441\u043A\u0456\u043D\u0447\u0435\u043D\u043D\u0438\u043C, \u0430
    \u0442\u0435\u043C\u0440\u044F\u0432\u0430 \u043F\u043E\u043F\u0435\u0440\u0435\u0434\u0443
    \u2014 \u0432\u0456\u0434\u0447\u0443\u0442\u043D\u043E\u044E \u043D\u0430 \u0434\u043E\u0442\u0438\u043A."
