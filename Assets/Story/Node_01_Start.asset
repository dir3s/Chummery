  background: {fileID: 6904444990699376935, guid: 871fd644bb4f76b4baa75a6e8f90e814, type: 3}
  dialogueText: "\u0414\u043E\u0432\u0433\u0438\u0439 \u043A\u043E\u0440\u0438\u0434\u043E\u0440,
    \u0442\u0443\u0441\u043A\u043B\u0435 \u043E\u0441\u0432\u0456\u0442\u043B\u0435\u043D\u043D\u044F,
    \u0456\u0437 \u043A\u0456\u043C\u043D\u0430\u0442 \u0447\u0443\u0442\u043D\u043E
    \u0448\u0443\u043C\r\n\r\n\r\n\u0423\u0441\u0435\u0440\u0435\u0434\u0438\u043D\u0456
    \u043F\u0430\u0445\u043D\u0435 \u043F\u0438\u043B\u043E\u043C, \u0434\u0435\u0448\u0435\u0432\u0438\u043C
    \u043E\u0441\u0432\u0456\u0436\u0443\u0432\u0430\u0447\u0435\u043C \u043F\u043E\u0432\u0456\u0442\u0440\u044F
    \u0456\u2026 \u0447\u0438\u043C\u043E\u0441\u044C \u0434\u0438\u0432\u043D\u0438\u043C.\r\n\u041D\u0430\u0447\u0435
    \u0446\u0435 \u043C\u0456\u0441\u0446\u0435 \u0436\u0438\u0432\u0435 \u0441\u0432\u043E\u0457\u043C
    \u0436\u0438\u0442\u0442\u044F\u043C.\r\n\r\n\u0412 \u043A\u043E\u0440\u0438\u0434\u043E\u0440\u0456"
  choices:
  - answerText: "\u041E\u0433\u043B\u044F\u043D\u0443\u0442\u0438\u0441\u044F \u0441\u043F\u043E\u043A\u0456\u0439\u043D\u043E"
    nextNode: {fileID: 11400000, guid: 07dddd8e30714cc449f1a5e3cc7ceee7, type: 2}
  - answerText: "\u041F\u0440\u0438\u0441\u043B\u0443\u0445\u0430\u0442\u0438\u0441\u044F
      \u0434\u043E \u0434\u0438\u0432\u043D\u043E\u0433\u043E \u0437\u0432\u0443\u043A\u0443"
    nextNode: {fileID: 11400000, guid: 5610cd625af807147864c455b3257e94, type: 2}
